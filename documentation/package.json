{
  "name": "docs",
  "version": "1.4.1",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "BASE_URL=/ docusaurus build && BASE_URL=/ docusaurus serve --host 0.0.0.0",
    "start:en": "BASE_URL=/ docusaurus start",
    "start:fr": "BASE_URL=/ docusaurus start --locale fr",
    "start:de": "BASE_URL=/ docusaurus start --locale de",
    "start:es": "BASE_URL=/ docusaurus start --locale es",
    "start:pt-br": "BASE_URL=/ docusaurus start --locale pt-BR",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "GIT_USER=wsj-br docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc",
    "lint": "eslint .",
    "translate": "pnpm -C .. run i18n:translate",
    "translate:ui": "pnpm -C .. run i18n:translate:ui",
    "translate:svg": "pnpm -C .. run i18n:translate:svg",
    "translate:docs": "pnpm -C .. run i18n:translate:docs",
    "translate:status": "pnpm -C .. run i18n:status",
    "i18n:extract": "pnpm -C .. run i18n:extract",
    "i18n:sync": "pnpm -C .. run i18n:sync",
    "i18n:glossary-generate": "pnpm -C .. run i18n:glossary-generate"
  },
  "dependencies": {
    "@docusaurus/core": "^3.10.0",
    "@docusaurus/plugin-client-redirects": "^3.10.0",
    "@docusaurus/preset-classic": "^3.10.0",
    "@docusaurus/theme-common": "^3.10.0",
    "@docusaurus/theme-mermaid": "^3.10.0",
    "@easyops-cn/docusaurus-search-local": "^0.55.1",
    "@iconify/react": "^6.0.2",
    "@mdx-js/react": "^3.1.1",
    "clsx": "^2.1.1",
    "docusaurus-plugin-image-zoom": "^3.0.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remark-github-alerts": "^0.1.1"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.0",
    "@docusaurus/tsconfig": "3.10.0",
    "@docusaurus/types": "3.10.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "typescript": "~6.0.3"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=18.0"
  }
}
