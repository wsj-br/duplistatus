{
  "sourceLocale": "en-GB",
  "targetLocales": ["de", "fr", "es", "pt-BR"],
  "openrouter": {
    "baseUrl": "https://openrouter.ai/api/v1",
    "translationModels": [
      "anthropic/claude-3.5-haiku",
      "qwen/qwen3-235b-a22b-2507",
      "openai/gpt-4o-mini",
      "deepseek/deepseek-v4-flash",
      "anthropic/claude-3-haiku",
      "qwen/qwen3.6-plus",
      "anthropic/claude-3.5-haiku",
      "google/gemini-3-flash-preview",
      "~anthropic/claude-haiku-latest",
      "google/gemma-4-31b-it",
      "~anthropic/claude-sonnet-latest",
      "openai/gpt-5.3-codex"
    ],
    "maxTokens": 8192,
    "temperature": 0.2
  },
  "features": {
    "extractUIStrings": true,
    "translateUIStrings": true,
    "translateMarkdown": true,
    "translateJSON": true,
    "translateSVG": true
  },
  "glossary": {
    "uiGlossary": "src/locales/strings.json",
    "userGlossary": "glossary-user.csv"
  },
  "ui": {
    "sourceRoots": ["src/"],
    "stringsJson": "src/locales/strings.json",
    "flatOutputDir": "src/locales/"
  },
  "cacheDir": ".translation-cache",
  "documentations": [
    {
      "description": "Docusaurus docs site",
      "contentPaths": ["documentation/docs"],
      "outputDir": "documentation/i18n",
      "jsonSource": "documentation/i18n/en-GB",
      "markdownOutput": {
        "style": "docusaurus",
        "docsRoot": "documentation/docs",
        "postProcessing": {
          "regexAdjustments": [
            {
              "description": "translate SVG images paths from /img to ../assets for duplistatus_ files",
              "search": "\\(/img/duplistatus_",
              "replace": "(../assets/duplistatus_"
            }
          ]
        }
      },
      "addFrontmatter": true
    }
  ],
  "svg": {
    "sourcePath": [
      "documentation/static/img/duplistatus_dash-cards.svg",
      "documentation/static/img/duplistatus_dash-table.svg",
      "documentation/static/img/duplistatus_toolbar.svg"
    ],
    "outputDir": "documentation/i18n",
    "style": "nested",
    "pathTemplate": "{outputDir}/{locale}/docusaurus-plugin-content-docs/current/assets/{basename}",
    "forceLowercase": true
  },
  "concurrency": 4,
  "batchConcurrency": 4,
  "batchSize": 20,
  "maxBatchChars": 4096,
  "uiLanguagesPath": "src/locales/ui-languages.json"
}
