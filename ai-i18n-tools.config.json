{
  "sourceLocale": "en-GB",
  "targetLocales": [
    "de",
    "fr",
    "es",
    "pt-BR",
    "zh-CN"
  ],
  "openrouter": {
    "baseUrl": "https://openrouter.ai/api/v1",
    "translationModels": [
      "google/gemma-4-31b-it",
      "anthropic/claude-3.5-haiku",
      "qwen/qwen3-235b-a22b-2507",
      "openai/gpt-4o-mini",
      "deepseek/deepseek-v4-flash",
      "anthropic/claude-3-haiku",
      "qwen/qwen3.6-plus",
      "anthropic/claude-3.5-haiku",
      "google/gemini-3-flash-preview",
      "~anthropic/claude-haiku-latest",
      "~anthropic/claude-sonnet-latest",
      "openai/gpt-5.3-codex"
    ],
    "maxTokens": 8192,
    "temperature": 0.2
  },
  "features": {
    "translateUIStrings": true,
    "translateSVG": true,
    "translateDocs": true
  },
  "glossary": {
    "uiGlossary": "src/locales/strings.json",
    "userGlossary": "glossary-user.csv"
  },
  "ui": {
    "sourceRoots": [
      "src/"
    ],
    "stringsJson": "src/locales/strings.json",
    "flatOutputDir": "src/locales/"
  },
  "cacheDir": ".translation-cache",
  "svg": {
    "sourcePath": [
      "documentation/static/assets/duplistatus_dash-cards.svg",
      "documentation/static/assets/duplistatus_toolbar.svg"
    ],
    "outputDir": "documentation/i18n",
    "style": "nested",
    "pathTemplate": "{outputDir}/{locale}/docusaurus-plugin-content-docs/current/assets/{basename}",
    "forceLowercase": true
  },
  "concurrency": 4,
  "batchConcurrency": 4,
  "batchSize": 20,
  "maxBatchChars": 4096,
  "uiLanguagesPath": "src/locales/ui-languages.json",
  "docs": [
    {
      "description": "Docusaurus docs site",
      "contentPaths": [
        "documentation/docs"
      ],
      "outputDir": "documentation/i18n",
      "addFrontmatter": false,
      "docusaurusCatalogDir": "documentation/i18n/en-GB",
      "docsOutput": {
        "style": "docusaurus",
        "docsRoot": "documentation/docs"
      }
    }
  ]
}
