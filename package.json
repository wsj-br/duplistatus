{
  "name": "duplistatus",
  "version": "1.4.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.12.0",
    "pnpm": ">=10.24.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "./scripts/pre-checks.sh && next build --webpack",
    "lint": "pnpm exec eslint .",
    "typecheck": "tsc --noEmit",
    "start": "NODE_ENV=production HOSTNAME=0.0.0.0 PORT=9666 node .next/standalone/server.js",
    "cron:start": "tsx src/cron-service/index.ts",
    "dev": "./scripts/pre-checks.sh && NODE_ENV=development PORT=8666 next dev",
    "cron:dev": "CRON_PORT=8667 tsx watch src/cron-service/index.ts",
    "build-local": "./scripts/pre-checks.sh && next build && mkdir -p .next/standalone/.next && cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public",
    "start-local": "./scripts/pre-checks.sh && NODE_ENV=production HOSTNAME=0.0.0.0 PORT=8666 CRON_PORT=8667 NEXT_TELEMETRY_DISABLED=1 node .next/standalone/server.js",
    "cron:start-local": "NODE_ENV=production CRON_PORT=8667 tsx watch src/cron-service/index.ts",
    "generate-test-data": "tsx scripts/generate-test-data.ts",
    "validate-csv-export": "tsx scripts/validate-csv-export.ts",
    "take-screenshots": "sh -c 'tsx --env-file=.env scripts/take-screenshots.ts \"$@\" 2>&1 | tee take-screenshots.log' _",
    "docker:up": "./scripts/pre-checks.sh && docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:clean": "./scripts/clean-docker.sh",
    "docker:devel": "docker build . -t wsj-br/duplistatus:devel",
    "test-entrypoint": "./scripts/test-entrypoint.sh",
    "i18n:extract": "ai-i18n-tools extract",
    "i18n:sync": "ai-i18n-tools sync",
    "i18n:translate": "ai-i18n-tools translate-ui && ai-i18n-tools translate-svg && ai-i18n-tools translate-docs",
    "i18n:translate:ui": "ai-i18n-tools translate-ui",
    "i18n:translate:svg": "ai-i18n-tools translate-svg",
    "i18n:translate:docs": "ai-i18n-tools translate-docs",
    "i18n:status": "ai-i18n-tools status",
    "i18n:editor": "ai-i18n-tools editor",
    "i18n:glossary-generate": "ai-i18n-tools glossary-generate -o documentation/glossary-user.csv",
    "i18n:generate-ui-languages": "ai-i18n-tools generate-ui-languages"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/bcrypt": "^6.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "ai-i18n-tools": "^1.1.1",
    "autoprefixer": "^10.5.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "i18next": "^26.0.5",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-datepicker": "^9.1.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^17.0.4",
    "recharts": "^3.8.1",
    "string-template": "^1.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "19.2.14",
    "@types/string-template": "^1.0.7",
    "baseline-browser-mapping": "latest",
    "eslint": "^9.39.3",
    "eslint-config-next": "16.2.4",
    "puppeteer": "^24.41.0",
    "tsx": "^4.21.0",
    "webpack": "^5.106.2"
  },
  "pnpm": {
    "overrides": {
      "qs": ">=6.14.1",
      "preact": ">=10.28.2",
      "lodash": ">=4.17.23",
      "lodash-es": ">=4.17.23",
      "@isaacs/brace-expansion": ">=5.0.1",
      "minimatch": ">=3.1.4",
      "serialize-javascript": ">=7.0.3",
      "svgo@>=3.0.0 <3.3.3": ">=3.3.3",
      "flatted@<3.4.0": ">=3.4.0",
      "undici@>=7.0.0 <7.24.0": ">=7.24.0",
      "undici@>=7.17.0 <7.24.0": ">=7.24.0",
      "flatted@<=3.4.1": ">=3.4.2",
      "path-to-regexp@<0.1.13": ">=0.1.13",
      "dompurify@<3.3.2": ">=3.3.2",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "path-to-regexp@>=8.0.0 <8.4.0": ">=8.4.0",
      "dompurify@>=3.1.3 <=3.3.1": ">=3.3.2",
      "serialize-javascript@<7.0.5": ">=7.0.5",
      "lodash-es@>=4.0.0 <=4.17.23": ">=4.18.0",
      "lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
      "lodash-es@<=4.17.23": ">=4.18.0",
      "lodash@<=4.17.23": ">=4.18.0",
      "dompurify@<=3.3.1": ">=3.3.2",
      "nodemailer@<=8.0.4": ">=8.0.5",
      "next@>=16.0.0-beta.0 <16.2.3": ">=16.2.3",
      "basic-ftp@<=5.2.1": ">=5.2.2",
      "basic-ftp@=5.2.0": ">=5.2.1",
      "follow-redirects@<=1.15.11": ">=1.16.0",
      "dompurify@<=3.3.3": ">=3.4.0",
      "basic-ftp@<=5.2.2": ">=5.3.0"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "webpack": "5"
      }
    },
    "allowedDeprecatedVersions": {
      "prebuild-install": "7.1.3",
      "whatwg-encoding": "3.1.1"
    }
  }
}