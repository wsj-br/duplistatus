{
  "name": "duplistatus",
  "version": "1.4.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=24.12.0",
    "pnpm": ">=10.24.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "./scripts/pre-checks.sh && next build --webpack",
    "lint": "pnpm exec eslint .",
    "typecheck": "tsc --noEmit",
    "start": "NODE_ENV=production HOSTNAME=0.0.0.0 PORT=9666 node .next/standalone/server.js",
    "cron:start": "tsx src/cron-service/index.ts",
    "dev": "./scripts/pre-checks.sh && NODE_ENV=development PORT=8666 next dev",
    "cron:dev": "CRON_PORT=8667 tsx watch src/cron-service/index.ts",
    "build-local": "./scripts/pre-checks.sh && next build && ./scripts/pos-build.sh",
    "start-local": "./scripts/pre-checks.sh && NODE_ENV=production HOSTNAME=0.0.0.0 PORT=8666 CRON_PORT=8667 NEXT_TELEMETRY_DISABLED=1 node .next/standalone/server.js",
    "cron:start-local": "NODE_ENV=production CRON_PORT=8667 tsx watch src/cron-service/index.ts",
    "generate-test-data": "tsx scripts/generate-test-data.ts",
    "validate-csv-export": "tsx scripts/validate-csv-export.ts",
    "take-screenshots": "sh -c 'tsx --env-file=.env scripts/take-screenshots.ts \"$@\" 2>&1 | tee take-screenshots.log' _",
    "docker:up": "./scripts/pre-checks.sh && docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:clean": "./scripts/clean-docker.sh",
    "docker:devel": "docker build . -t wsj-br/duplistatus:devel",
    "test-entrypoint": "./scripts/test-entrypoint.sh",
    "i18n:extract": "ai-i18n-tools extract",
    "i18n:sync": "ai-i18n-tools sync",
    "i18n:translate": "ai-i18n-tools translate-ui && ai-i18n-tools translate-svg && ai-i18n-tools translate-docs",
    "i18n:translate:ui": "ai-i18n-tools translate-ui",
    "i18n:translate:svg": "ai-i18n-tools translate-svg",
    "i18n:translate:docs": "ai-i18n-tools translate-docs",
    "i18n:status": "ai-i18n-tools status",
    "i18n:editor": "ai-i18n-tools editor",
    "i18n:glossary-generate": "ai-i18n-tools glossary-generate -o documentation/glossary-user.csv",
    "i18n:generate-ui-languages": "ai-i18n-tools generate-ui-languages"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.3.0",
    "postcss": "^8.5.14",
    "serialize-javascript": "^7.0.5",
    "@types/bcrypt": "^6.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "ai-i18n-tools": "^1.4.1",
    "autoprefixer": "^10.5.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "i18next": "^26.1.0",
    "lucide-react": "^1.14.0",
    "next": "16.3.0-canary.19",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-datepicker": "^9.1.0",
    "react-day-picker": "^10.0.0",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.75.0",
    "react-i18next": "^17.0.7",
    "recharts": "^3.8.1",
    "string-template": "^1.0.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.7.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "19.2.14",
    "@types/string-template": "^1.0.7",
    "baseline-browser-mapping": "latest",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "express": "5.2.1",
    "puppeteer": "^24.43.1",
    "tsx": "^4.21.0",
    "webpack": "^5.106.2"
  }
}